# =============================================================================
# 业务运行时环境变量样板
# 复制为 .env.local（本地开发）或 .env.production.local（构建）使用
# .env.local 不进 git；本文件 .env.example 进 git，作为 schema
# =============================================================================

# Vite 公开变量（会暴露给浏览器，仅放非敏感信息）
# 必须以 VITE_ 开头
VITE_APP_NAME=bitfe-vue-app
VITE_API_BASE_URL=https://api.example.com

# 第三方服务（按需启用）
# VITE_SENTRY_DSN=
