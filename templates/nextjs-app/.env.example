# =============================================================================
# 业务运行时环境变量样板
# 复制为 .env.local（本地开发）或 .env.production.local（构建）使用
# .env.local 不进 git；本文件 .env.example 进 git，作为 schema
# =============================================================================

# Next.js 公开变量（会暴露给浏览器，仅放非敏感信息）
# 必须以 NEXT_PUBLIC_ 开头
NEXT_PUBLIC_APP_NAME=bitfe-nextjs-app
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# 服务端变量（仅 server / route handlers / server actions 可读）
# 不要加 NEXT_PUBLIC_ 前缀
DATABASE_URL=postgres://user:pass@localhost:5432/db
SESSION_SECRET=replace-me-with-32-byte-random-string

# 第三方服务（按需启用）
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
