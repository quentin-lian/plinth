{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":dependencyDashboard",
    ":maintainLockFilesWeekly",
    ":automergeMinor",
    "schedule:earlyMondays"
  ],
  "timezone": "Asia/Shanghai",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "把 patch 升级聚合成一个周 PR",
      "matchUpdateTypes": ["patch"],
      "groupName": "all-patch-dependencies",
      "groupSlug": "all-patch",
      "schedule": ["before 6am on monday"]
    },
    {
      "description": "ESLint 生态聚合：插件 + 规则常一起走",
      "matchPackageNames": [
        "eslint",
        "@eslint/**",
        "eslint-config-**",
        "eslint-plugin-**",
        "typescript-eslint",
        "@typescript-eslint/**",
        "vue-eslint-parser"
      ],
      "groupName": "eslint",
      "groupSlug": "eslint"
    },
    {
      "description": "Prettier 生态聚合",
      "matchPackageNames": [
        "prettier",
        "prettier-plugin-**",
        "@ianvs/prettier-plugin-sort-imports"
      ],
      "groupName": "prettier",
      "groupSlug": "prettier"
    },
    {
      "description": "Vitest + Testing Library 生态聚合",
      "matchPackageNames": ["vitest", "@vitest/**", "jsdom", "@testing-library/**"],
      "groupName": "test-stack",
      "groupSlug": "test-stack"
    },
    {
      "description": "Next.js + React 生态聚合（major 单独 PR）",
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "eslint-config-next",
        "@next/eslint-plugin-next"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "nextjs",
      "groupSlug": "nextjs"
    },
    {
      "description": "Vue 生态聚合（major 单独 PR）",
      "matchPackageNames": [
        "vue",
        "vue-tsc",
        "@vue/**",
        "@vitejs/plugin-vue",
        "vue-eslint-parser",
        "eslint-plugin-vue"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "vue",
      "groupSlug": "vue"
    },
    {
      "description": "Major 升级单独 PR，附迁移说明",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    },
    {
      "description": "TypeScript major 单独评审",
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "typescript-major"],
      "automerge": false
    },
    {
      "description": "锁定 Node engines（pinDigest 不动）",
      "matchDepTypes": ["engines"],
      "enabled": false
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/dist/**"]
}
