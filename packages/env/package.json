{
  "name": "@plinth/env",
  "version": "0.0.0",
  "description": "运行时环境变量校验工具，基于 zod。启动时缺失或非法变量直接抛错，避免线上裸奔。",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint --max-warnings 0 src",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "zod": "^3.22.0 || ^4.0.0"
  },
  "devDependencies": {
    "@plinth/eslint-config": "workspace:*",
    "@plinth/test-config": "workspace:*",
    "@plinth/typescript-config": "workspace:*",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^4",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
